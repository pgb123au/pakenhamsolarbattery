---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Page not found | Pakenham Solar &amp; Battery"
  description="The page you were looking for couldn't be found. Get a free solar &amp; battery quote on (03) 9003 0108."
  canonical="https://pakenhamsolarbattery.com.au/404/">
  <Fragment slot="head">
    <meta name="robots" content="noindex, follow">
  </Fragment>

  <section class="hero">
    <div class="hero-inner" style="text-align:center;">
      <span class="hero-eyebrow">404</span>
      <h1 style="margin-left:auto; margin-right:auto;">Couldn&rsquo;t find that page.</h1>
      <p class="hero-sub" style="margin-left:auto; margin-right:auto;">
        Try the home page or call us &mdash; we&rsquo;ll point you in the right direction.
      </p>
      <div class="hero-actions" style="justify-content:center;">
        <a class="btn btn-primary" href="/">Back to home</a>
        <a class="btn btn-ghost" href="tel:+61390030108">&#9742; (03) 9003 0108</a>
      </div>
    </div>
  </section>
</Layout>
